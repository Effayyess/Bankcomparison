# ============================================================
# Business Bank Compare — Environment Variables
# Copy this file to .env.local for local development.
# In production, set these in the Netlify dashboard under
# Site Settings → Environment Variables.
# ============================================================

# Resend API Key (required for newsletter + contact form)
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend Audience ID (optional — for newsletter contact list)
# Create an audience at: https://resend.com/audiences
# Then paste the audience ID here.
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Email address that receives contact form submissions
# Defaults to info@businessbankcompare.co.uk if not set
CONTACT_EMAIL_TO=info@businessbankcompare.co.uk
